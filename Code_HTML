<!DOCTYPE html>
<html>
<head>
<title>Online Event Registration</title>

<!-- External CSS Linking -->
<link rel="stylesheet" href="style1.css">

</head>

<body>

<div class="container">

<h1>Online Event Registration</h1>

<div class="media-section">

<img src="C:\Users\hemal\Downloads\echnolo.png" alt="Event Banner" width="400">

<video width="400" controls>
<source src="C:\Users\hemal\Downloads\videoplayback.1768882372167.publer.com.mp4" type="video/mp4">
</video>

<audio controls>
<source src="C:\Users\hemal\Downloads\sb_adriftamonginfinitestars(chosic.com).mp3" type="audio/mpeg">
</audio>

</div>

<h2>Register for the Event</h2>

<form>

<label>Name:</label>
<input type="text" name="name" placeholder="Enter your name" required minlength="3">

<br><br>

<label>Email:</label>
<input type="email" name="email" placeholder="Enter your email" required>

<br><br>

<label>Event Date:</label>
<input type="date" name="date" required>

<br><br>

<label>Gender:</label>
<input type="radio" name="gender" value="Male" required> Male
<input type="radio" name="gender" value="Female"> Female

<br><br>

<label>Select Event Type:</label>
<select required>
<option value="">Select Event</option>
<option>Workshop</option>
<option>Seminar</option>
<option>Conference</option>
<option>Webinar</option>
</select>

<br><br>

<label>Comments:</label><br>
<textarea rows="4" cols="40" placeholder="Enter comments"></textarea>

<br><br>

<label>Upload ID Proof:</label>
<input type="file" accept=".pdf,.jpg,.png" required>

<br><br>

<input type="submit" value="Register">

</form>

</div>

</body>
</html>
